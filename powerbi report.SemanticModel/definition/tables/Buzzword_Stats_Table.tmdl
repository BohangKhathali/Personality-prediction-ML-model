table Buzzword_Stats_Table
	lineageTag: 306af5e1-bb39-4bed-971b-a1eacf3c9ef3

	column Personality
		lineageTag: 1d8dee04-bbc7-4736-b1e1-b0bf847378c2
		summarizeBy: none
		isNameInferred
		sourceColumn: [Personality]

		annotation SummarizationSetBy = Automatic

	column Buzzword
		lineageTag: 42211105-4eaf-43f8-ab26-f15e08b38a98
		summarizeBy: none
		isNameInferred
		sourceColumn: [Buzzword]

		annotation SummarizationSetBy = Automatic

	column Total_Appearances
		lineageTag: 52fd5d06-fecb-475c-bd28-6fdfd202c6c5
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Total_Appearances]

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition Buzzword_Stats_Table = calculated
		mode: import
		source = ```
				
				VAR CombinedBase = CROSSJOIN(
				    VALUES('cleaned_data'[personality_type]), 
				    VALUES('Keyword_Library'[Buzzwords])
				)
				RETURN
				SELECTCOLUMNS(
				    CombinedBase,
				    "Personality", [personality_type],
				    "Buzzword", [Buzzwords],
				    "Total_Appearances", 
				    VAR CurrentType = [personality_type]
				    VAR CurrentWord = [Buzzwords]
				    RETURN
				    SUMX(
				        FILTER('cleaned_data', 'cleaned_data'[personality_type] = CurrentType),
				        (LEN('cleaned_data'[posts]) - LEN(SUBSTITUTE(LOWER('cleaned_data'[posts]), LOWER(CurrentWord), ""))) / LEN(CurrentWord)
				    )
				)
				```

	annotation PBI_Id = e2c260502ce24a6fad382482a281a1d8

